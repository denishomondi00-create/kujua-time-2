{
  "name": "kujua-time",
  "version": "0.1.0",
  "private": true,
  "description": "Kujua Time monorepo, branded scheduling, payments, reminders, CRM, and automations for service businesses.",
  "packageManager": "pnpm@9.15.1",
  "engines": {
    "node": "^20.18.0 || ^22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @kujua-time/web dev",
    "dev:api": "pnpm --filter @kujua-time/api start:dev",
    "dev:worker": "pnpm --filter @kujua-time/worker start:dev",
    "dev:scheduler": "pnpm --filter @kujua-time/scheduler start:dev",
    "dev:docs": "pnpm --filter @kujua-time/docs dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean || true && rm -rf node_modules .turbo",
    "format": "prettier --write .",
    "compose:up": "docker compose -f infra/compose/docker-compose.yml up -d",
    "compose:down": "docker compose -f infra/compose/docker-compose.yml down",
    "bootstrap": "bash scripts/bootstrap.sh"
  },
  "devDependencies": {
    "@changesets/cli": "^2.28.1",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
